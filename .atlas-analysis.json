  "keyFeatures": [
    "Concise command routing with support for slash commands, text patterns, and Telegram update types",
    "Middleware system with global, group, and handler-level scopes",
    "Transparent File API that handles upload, download, and caching automatically",
    "Flexible keyboard builder supporting both reply and inline keyboards",
    "Inline mode support for responding to inline queries with rich result types",
    "Long-polling and webhook pollers with a custom Poller interface",
    "Layout package for YAML-driven bot configuration and i18n locales",
    "Context interface wrapping updates with helpers for all common operations"
  ],
  "publicApiSurface": [
    "NewBot(pref Settings) (*Bot, error)",
    "Bot.Handle(endpoint interface{}, h HandlerFunc, m ...MiddlewareFunc)",
    "Bot.Start()",
    "Bot.Stop()",
    "Bot.Send(to Recipient, what interface{}, opts ...interface{}) (*Message, error)",
    "Bot.Edit(msg Editable, what interface{}, opts ...interface{}) (*Message, error)",
    "Bot.Delete(msg Editable) error",
    "Bot.Use(middleware ...MiddlewareFunc)",
    "Bot.Group() *Group",
    "Context (interface)",
    "HandlerFunc",
    "MiddlewareFunc",
    "Poller (interface)",
    "LongPoller",
    "Webhook",
